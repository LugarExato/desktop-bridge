{
  "name": "desktop-bridge",
  "version": "1.0.0",
  "description": "Lugar Exato Desktop Bridge - Automação Residencial e Comercial via WhatsApp",
  "main": "main.js",
  "author": "",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.lugarexato.bridge",
    "productName": "Lugar Exato Bridge",
    "copyright": "Copyright © 2026 Lugar Exato",
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.png",
      "verifyUpdateCodeSignature": false,
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "license": "build/license.txt",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lugar Exato Bridge"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "lugarexato",
        "repo": "desktop-bridge"
      }
    ]
  },
  "keywords": [],
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "electron-updater": "^6.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  }
}
